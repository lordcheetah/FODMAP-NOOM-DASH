# Copy to .env.local and fill in from your Supabase project
# (Supabase dashboard -> Project Settings -> API). NEVER commit real keys.

# The "anon" public key is safe to ship in a client app ONLY because Row-Level
# Security (RLS) is enabled on every table — see supabase/migrations.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The app runs without these (offline/demo shell), but auth + cloud sync are
# disabled until they are set.
